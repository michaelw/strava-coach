{
  "name": "strava-coach-pages",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-22-bookworm",
  "forwardPorts": [
    1313
  ],
  "portsAttributes": {
    "1313": {
      "label": "Hugo",
      "onAutoForward": "openBrowser"
    }
  },
  "otherPortsAttributes": {
    "label": "Hugo",
    "onAutoForward": "openBrowser"
  },
  "mounts": [
    "source=apt-cache-${devcontainerId},target=/var/cache/apt,type=volume",
    "source=apt-lists-${devcontainerId},target=/var/lib/apt/lists,type=volume"
  ],
  "runArgs": [
    "--security-opt=seccomp=unconfined",
    "--security-opt=apparmor=unconfined"
  ],
  "postCreateCommand": "bash scripts/devcontainer-post-create.sh",
  "customizations": {
    "vscode": {
      "mcp": {
        "servers": {
          "github": {
            "type": "http",
            "url": "https://api.githubcopilot.com/mcp/"
          }
        }
      },
      "settings": {
        "files.exclude": {
          "**/public": true
        },
        "yaml.schemas": {
          "https://taskfile.dev/schema.json": "Taskfile.yml"
        },
        "taskfile.path": "task",
        "task.allowAutomaticTasks": "on"
      },
      "extensions": [
        "DavidAnson.vscode-markdownlint",
        "GitHub.vscode-github-actions",
        "GitHub.vscode-pull-request-github",
        "stuartleeks.vscode-hugo-runner",
        "task.vscode-task",
        "redhat.vscode-yaml",
        "streetsidesoftware.code-spell-checker",
        "yzhang.markdown-all-in-one"
      ]
    }
  }
}
