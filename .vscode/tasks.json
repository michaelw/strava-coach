{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Jekyll Serve",
      "type": "shell",
      "command": "if [ -f /.dockerenv ]; then bundle exec jekyll serve --host 0.0.0.0 --livereload; else echo 'Skipping Jekyll Serve auto-start (not running inside a devcontainer).'; fi",
      "isBackground": true,
      "problemMatcher": {
        "owner": "jekyll",
        "pattern": {
          "regexp": "^.*$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Auto-regeneration.*$",
          "endsPattern": "^.*Server running.*$"
        }
      },
      "presentation": {
        "reveal": "never",
        "panel": "dedicated",
        "focus": false
      }
    }
  ]
}
