{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Jekyll Serve",
      "type": "shell",
      "command": "bundle exec jekyll serve --host 0.0.0.0 --livereload",
      "isBackground": true,
      "problemMatcher": {
        "owner": "jekyll",
        "pattern": {
          "regexp": "^.*$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Auto-regeneration.*$",
          "endsPattern": "^.*Server running.*$"
        }
      },
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    }
  ]
}
